# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
venv/
.venv/
env/

# Environment variables -- contains secrets, never commit this
.env
# .env.example is intentionally NOT ignored (it is the safe template)

# Local data folders -- ignore contents but track .gitkeep scaffold
output/*
!output/.gitkeep
source/*
!source/.gitkeep

# Embedding cache -- computed locally, no need to share
.embedding_cache.pkl

# Logs
flashcard_generator.log
*.log

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
